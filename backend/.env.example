SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
OPENAI_API_KEY=your_openai_api_key_here
LOCAL_STORAGE_PATH=./data/storage
LOCAL_USER_EMAIL=assistant@local
LOCAL_USER_NAME=assistant
LOCAL_USER_DEPARTMENT=Local

# Optional manual overrides if you are not using `docker compose up -d`
# DATABASE_URL=postgresql+psycopg://assistant:assistant@127.0.0.1:5432/assistant
# REDIS_URL=redis://127.0.0.1:6379/0
# FRONTEND_URL=http://localhost:3000
# API_BASE_URL=http://localhost:8000
# SANDBOX_URL=http://127.0.0.1:8100
